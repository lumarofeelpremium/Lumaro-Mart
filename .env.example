# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_API_KEY"

# GOOGLE_API_KEY: Alternative name for Gemini API key often used in @google/genai docs.
GOOGLE_API_KEY="YOUR_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# FIREBASE_SERVICE_ACCOUNT: Required for Push Notifications.
# Go to Firebase Console > Project Settings > Service Accounts > Generate new private key.
# Paste the entire JSON content as a single line or stringified JSON here.
# You can also base64 encode the JSON if it helps with formatting.
FIREBASE_SERVICE_ACCOUNT=
