{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information including loyalty points and address.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "address": { "type": "string" },
        "pincode": { "type": "string" },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["uid", "email", "displayName", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details for the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "salesCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "image", "category", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "icon"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "subtotal": { "type": "number" },
        "delivery": { "type": "number" },
        "pointsRedeemed": { "type": "number" },
        "pointsEarned": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Promotional banners for the home screen.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "buttonText": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "active": { "type": "boolean" }
      },
      "required": ["title", "subtitle", "buttonText", "backgroundColor", "active"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "whatsappNumber": { "type": "string" }
      },
      "required": ["whatsappNumber"]
    },
    "Notification": {
      "title": "Notification",
      "description": "App notifications for users.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["new_product", "offer", "order_update"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "productId": { "type": "string" }
      },
      "required": ["title", "message", "type", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product reviews from users.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "Products saved by users for later.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "createdAt"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User's persistent cart items.",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Home screen banners."
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global app settings."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "App notifications."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    },
    "/wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User wishlist items."
    },
    "/carts/{userId}": {
      "schema": "Cart",
      "description": "User persistent shopping carts."
    }
  }
}
